{
  "name": "vibe-coding-agent",
  "version": "0.1.0",
  "description": "Multi-channel AI Agent framework with shared sessions",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "bun test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.0.0",
    "ioredis": "^5.3.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/qrcode": "^1.5.6",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
